<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grundläggande Koordinatgeometri</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- MathJax for rendering math formulas -->
    <script>
        window.MathJax = {
            tex: {
                inlineMath: [['$', '$'], ['\\(', '\\)']],
                displayMath: [['$$', '$$'], ['\\[', '\\]']]
            },
            startup: {
                typeset: false
            }
        };
    </script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f3f4f6; }
        .fade-in { animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .option-btn {
            transition: all 0.2s;
        }
        .option-btn:hover:not(:disabled) {
            transform: scale(1.02);
            border-color: #3b82f6;
        }
        .correct { background-color: #d1fae5; border-color: #10b981; color: #065f46; }
        .wrong { background-color: #fee2e2; border-color: #ef4444; color: #991b1b; }
        .disabled { opacity: 0.6; cursor: not-allowed; }
        .formula-box { border-left-width: 4px; border-color: #3b82f6; }
    </style>
</head>
<body class="min-h-screen text-gray-800 p-4 md:p-8 flex items-center justify-center">

    <div id="app" class="max-w-5xl w-full bg-white rounded-2xl shadow-xl overflow-hidden fade-in">
        <!-- Content gets injected here -->
    </div>

    <script>
        const questions = [
            {
                q: "Vad är avståndet mellan punkterna (1, 2) och (4, 2)?",
                options: ["3", "4", "5", "2"],
                correct: 0,
                rationale: "Eftersom y-koordinaten är 2 för båda punkterna ligger de på en vågrät linje. Avståndet är skillnaden i x-led: $4 - 1 = 3$."
            },
            {
                q: "Vilket uttryck visar avståndet mellan origo (0, 0) och punkten (3, 4)?",
                options: ["$3^2 + 4^2$", "$\\sqrt{3 + 4}$", "$\\sqrt{3^2 + 4^2}$", "$\\frac{4-0}{3-0}$"],
                correct: 2,
                rationale: "Enligt avståndsformeln (eller Pythagoras sats) tar vi kvadraten på kateterna och drar roten ur: $\\sqrt{(3-0)^2 + (4-0)^2} = \\sqrt{3^2 + 4^2}$."
            },
            {
                q: "Vilken punkt ligger exakt mitt emellan (2, 0) och (6, 0)?",
                options: ["(3, 0)", "(8, 0)", "(4, 4)", "(4, 0)"],
                correct: 3,
                rationale: "Mittpunkten fås genom medelvärdet: $x_m = (2+6)/2 = 4$ och $y_m = (0+0)/2 = 0$."
            },
            {
                q: "Hur beräknar man x-koordinaten för mittpunkten mellan $(x_1, y_1)$ och $(x_2, y_2)$?",
                options: ["Man adderar x-värdena och delar på 2", "Man subtraherar x-värdena från varandra", "Man multiplicerar x-värdena", "Man tar differensen och delar på 2"],
                correct: 0,
                rationale: "Mittpunkten är medelvärdet av koordinaterna: $x_m = \\frac{x_1 + x_2}{2}$."
            },
            {
                q: "Hur beräknar man k-värdet för en linje genom två punkter?",
                options: ["$\\Delta x / \\Delta y$", "$x_1 + x_2$", "$\\Delta y / \\Delta x$", "$\\sqrt{\\Delta x^2 + \\Delta y^2}$"],
                correct: 2,
                rationale: "Lutningen $k$ definieras som förändring i y-led dividerat med förändring i x-led."
            },
            {
                q: "Om en linje har k = 2, vilken lutning har en linje som är vinkelrät mot denna?",
                options: ["2", "-2", "0,5", "-0,5"],
                correct: 3,
                rationale: "För vinkelräta linjer gäller $k_1 \\cdot k_2 = -1$. Eftersom $2 \\cdot (-0,5) = -1$ är rätt svar -0,5."
            },
            {
                q: "Vad krävs för att en triangel ska kallas 'likbent'?",
                options: ["Minst två sidor är lika långa", "Alla tre sidor är lika långa", "En vinkel är 90 grader", "Sidan ligger på x-axeln"],
                correct: 0,
                rationale: "En likbent triangel har minst två sidor (ben) som är lika långa."
            },
            {
                q: "En sträcka börjar i (0, 0) och har mittpunkten (2, 2). Var slutar den?",
                options: ["(1, 1)", "(2, 2)", "(4, 4)", "(4, 2)"],
                correct: 2,
                rationale: "Eftersom mittpunkten är halvvägs måste den totala ändringen vara dubbelt så stor: $2 \\cdot 2 = 4$."
            },
            {
                q: "Beräkna avståndet mellan (0,0) och (3,4).",
                options: ["7", "5", "1", "25"],
                correct: 1,
                rationale: "$\\sqrt{3^2 + 4^2} = \\sqrt{9 + 16} = \\sqrt{25} = 5$."
            },
            {
                q: "Om $k_1 \\cdot k_2 = -1$, hur förhåller sig linjerna till varandra?",
                options: ["De är parallella", "De är identiska", "De är vinkelräta", "De skär aldrig varandra"],
                correct: 2,
                rationale: "Detta är villkoret för vinkelräta linjer."
            }
        ];

        let originalQueue = [...Array(questions.length).keys()];
        let retryQueue = [];
        let currentQueue = originalQueue;
        let queueIndex = 0;
        let phase = 'start'; 
        let score = 0;
        let hasAnsweredCurrent = false;

        const appDiv = document.getElementById('app');

        function renderMath() {
            if (window.MathJax && window.MathJax.typesetPromise) {
                window.MathJax.typesetPromise([appDiv]).catch((err) => console.log(err.message));
            }
        }

        function renderStartScreen() {
            appDiv.innerHTML = `
                <div class="p-12 text-center fade-in">
                    <h1 class="text-4xl font-bold text-blue-600 mb-6">Koordinatgeometri: Quiz</h1>
                    <p class="text-xl text-gray-600 mb-10 leading-relaxed">
                        Träna på avståndsformeln, mittpunkter och vinkelräta linjer.<br>
                        En komplett formelsamling finns tillgänglig under hela quizet.
                    </p>
                    <button onclick="startQuiz()" class="bg-blue-600 text-white px-10 py-4 rounded-full text-xl font-bold hover:bg-blue-700 transition shadow-xl hover:shadow-2xl">Starta Quizet</button>
                </div>
            `;
            renderMath();
        }

        function startQuiz() {
            phase = 'main';
            queueIndex = 0;
            score = 0;
            retryQueue = [];
            currentQueue = [...originalQueue];
            renderQuestion();
        }

        function renderQuestion() {
            hasAnsweredCurrent = false;
            const qIndex = currentQueue[queueIndex];
            const qData = questions[qIndex];
            const progress = phase === 'main' 
                ? `Fråga ${queueIndex + 1} av ${currentQueue.length}`
                : `Repetition: ${queueIndex + 1} av ${currentQueue.length}`;

            appDiv.innerHTML = `
                <div class="bg-blue-600 text-white p-4 flex justify-between items-center shadow-md">
                    <h2 class="text-lg font-bold uppercase tracking-wider">Geometri & Koordinater</h2>
                    <span class="bg-blue-800 px-3 py-1 rounded-full text-sm font-bold">${progress}</span>
                </div>

                <div class="flex flex-col lg:flex-row">
                    <!-- Vänster: Fråga -->
                    <div class="lg:w-2/3 p-8">
                        ${phase === 'retry' ? '<div class="mb-4 inline-block bg-orange-100 text-orange-700 text-xs font-bold px-2 py-1 rounded uppercase">Repeterar felaktigt svar</div>' : ''}
                        <h3 class="text-2xl font-semibold mb-8 text-gray-800 leading-snug">${qData.q}</h3>
                        
                        <div class="grid grid-cols-1 gap-4" id="options-container">
                            ${qData.options.map((opt, i) => `
                                <button onclick="checkAnswer(${i})" id="btn-${i}" class="option-btn text-left p-5 rounded-xl border-2 border-gray-200 bg-white font-medium text-lg text-gray-700 hover:border-blue-400 focus:outline-none">
                                    ${opt}
                                </button>
                            `).join('')}
                        </div>

                        <div id="feedback-container" class="mt-8 hidden rounded-2xl p-6 fade-in border-2">
                            <p id="feedback-text" class="font-bold text-xl mb-3"></p>
                            <p id="rationale-text" class="text-gray-700 leading-relaxed"></p>
                            <button id="next-btn" onclick="nextQuestion()" class="mt-6 bg-gray-800 text-white px-8 py-3 rounded-xl font-bold hover:bg-black transition">
                                ${queueIndex + 1 === currentQueue.length ? 'Visa resultat' : 'Nästa fråga'}
                            </button>
                        </div>
                    </div>

                    <!-- Höger: Formelsamling -->
                    <div class="lg:w-1/3 p-8 bg-gray-50 border-t lg:border-t-0 lg:border-l border-gray-200">
                        <div class="sticky top-8">
                            <h4 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-6">Formelsamling (NP)</h4>
                            
                            <div class="space-y-8">
                                <div class="formula-box pl-4">
                                    <p class="text-xs font-bold text-blue-600 mb-1">AVSTÅNDSFORMELN</p>
                                    <p class="text-lg">$$d = \\sqrt{(x_2-x_1)^2 + (y_2-y_1)^2}$$</p>
                                </div>

                                <div class="formula-box pl-4">
                                    <p class="text-xs font-bold text-blue-600 mb-1">MITTPUNKTSFORMELN</p>
                                    <p class="text-lg">$$x_m = \\frac{x_1+x_2}{2}, \\; y_m = \\frac{y_1+y_2}{2}$$</p>
                                </div>

                                <div class="formula-box pl-4">
                                    <p class="text-xs font-bold text-blue-600 mb-1">RIKTSNINGSKOEFFICIENT ($k$)</p>
                                    <p class="text-lg">$$k = \\frac{y_2-y_1}{x_2-x_1}$$</p>
                                </div>

                                <div class="formula-box pl-4">
                                    <p class="text-xs font-bold text-blue-600 mb-1">VINKELRÄTA LINJER</p>
                                    <p class="text-lg">$$k_1 \\cdot k_2 = -1$$</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            renderMath();
        }

        function checkAnswer(idx) {
            if (hasAnsweredCurrent) return;
            hasAnsweredCurrent = true;

            const qIndex = currentQueue[queueIndex];
            const qData = questions[qIndex];
            const isCorrect = idx === qData.correct;

            if (isCorrect) {
                if (phase === 'main') score++;
            } else {
                if (!retryQueue.includes(qIndex)) retryQueue.push(qIndex);
            }

            document.querySelectorAll('.option-btn').forEach((btn, i) => {
                btn.disabled = true;
                btn.classList.add('disabled');
                if (i === qData.correct) btn.classList.add('correct');
                else if (i === idx) btn.classList.add('wrong');
            });

            const fb = document.getElementById('feedback-container');
            const fbt = document.getElementById('feedback-text');
            const rt = document.getElementById('rationale-text');

            fb.classList.remove('hidden');
            fb.className = isCorrect 
                ? "mt-8 rounded-2xl p-6 fade-in border-2 bg-green-50 border-green-200 text-green-900" 
                : "mt-8 rounded-2xl p-6 fade-in border-2 bg-red-50 border-red-200 text-red-900";
            
            fbt.innerText = isCorrect ? "Snyggt! Helt rätt." : "Inte riktigt rätt...";
            rt.innerHTML = qData.rationale;
            renderMath();
        }

        function nextQuestion() {
            queueIndex++;
            if (queueIndex < currentQueue.length) {
                renderQuestion();
            } else {
                if (retryQueue.length > 0) {
                    currentQueue = [...retryQueue];
                    retryQueue = [];
                    queueIndex = 0;
                    phase = 'retry';
                    renderRetryNotice();
                } else {
                    renderEndScreen();
                }
            }
        }

        function renderRetryNotice() {
            appDiv.innerHTML = `
                <div class="p-12 text-center fade-in">
                    <div class="inline-block p-4 rounded-full bg-orange-100 mb-6">
                        <svg class="w-12 h-12 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    </div>
                    <h2 class="text-3xl font-bold mb-4">Repetition är kunskapens moder!</h2>
                    <p class="text-xl text-gray-600 mb-8">Vi går igenom de frågor som var kluriga en gång till så att de fastnar.</p>
                    <button onclick="renderQuestion()" class="bg-orange-500 text-white px-10 py-4 rounded-full text-xl font-bold hover:bg-orange-600 transition shadow-lg">Starta repetition</button>
                </div>
            `;
        }

        function renderEndScreen() {
            const perc = Math.round((score / questions.length) * 100);
            appDiv.innerHTML = `
                <div class="p-12 text-center fade-in">
                    <div class="inline-block p-4 rounded-full bg-green-100 mb-6">
                        <svg class="w-12 h-12 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h2 class="text-4xl font-bold mb-2">Quizet är klart!</h2>
                    <p class="text-2xl text-blue-600 font-bold mb-6">${score} av ${questions.length} rätt på första försöket (${perc}%)</p>
                    <p class="text-lg text-gray-600 mb-10 max-w-lg mx-auto">Du har nu repeterat alla frågor och svarat rätt på samtliga. Bra kämpat!</p>
                    <button onclick="startQuiz()" class="border-2 border-blue-600 text-blue-600 px-8 py-3 rounded-full font-bold hover:bg-blue-50 transition">Gör om hela quizet</button>
                </div>
            `;
        }

        renderStartScreen();
    </script>
</body>
</html>
